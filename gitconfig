[core]
	excludesfile = ~/src/dotfiles/git/gitignore_global
	hooksPath = /Users/rb/.git-hooks

[alias]
	lp = log -p
	lol = log --graph --decorate --pretty=oneline --abbrev-commit
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
	co = checkout
	st = status
	ci = commit
	di = diff
	dc = diff --cached
	pr = pull-request

[color]
	ui = true

[init]
	defaultBranch = main

[push]
	default = current
  # gpgSign = if-asked # Auto-enable when GitHub et al ship the feature

[filter "media"]
	clean = git-media-clean %f
	smudge = git-media-smudge %f
[hub]
	protocol = ssh
[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true

# Sign commits with 1Password-stored SSH key (https://developer.1password.com/docs/ssh/git-commit-signing/)
[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[user]
	name = Ryan Brooks
	email = ryan@slatehorse.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAQKMDHbcgXZN32J03mcyCuNLTT00ud4fVbmrmM/aHnl

# Custom email for Goodbase (catch remotes and local file location)
[includeIf "gitdir:~/src/goodbase/"]
  path = ~/src/dotfiles/git/config-github-goodbase
[includeIf "hasconfig:remote.*.url:git@github.com:goodbasehq/**"]
  path = ~/src/dotfiles/git/config-github-goodbase

