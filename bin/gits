#!/usr/bin/env ruby
# gits — multi-repo git status summariser
# Config: ~/.config/gits/config.yml (override base / scope / depth / ignore)

require "open3"
require "optparse"
require "pathname"
require "yaml"

XDG = Pathname.new(ENV.fetch("XDG_CONFIG_HOME") { "#{ENV["HOME"]}/.config" })
CONFIG_PATH = XDG.join("gits", "config.yml")

DEFAULT_CONFIG = {
  "base" => "~/src",
  "default_scope" => "~/src",
  "max_depth" => 4,
  "fetch" => true,
  "ignore" => %w[.Trash node_modules vendor]
}.freeze

module Ansi
  RESET = "\e[0m"
  BOLD = "\e[1m"
  DIM = "\e[2m"
  RED = "\e[31m"
  GREEN = "\e[32m"
  YELLOW = "\e[33m"
  CYAN = "\e[36m"
  MAGENTA = "\e[35m"
end

class Painter
  def initialize(enabled)
    @on = enabled
  end

  def wrap(text, *codes)
    return text unless @on
    codes.join + text + Ansi::RESET
  end

  def bold(t)        = wrap(t, Ansi::BOLD)
  def dim(t)         = wrap(t, Ansi::DIM)
  def red(t)         = wrap(t, Ansi::RED)
  def green(t)       = wrap(t, Ansi::GREEN)
  def yellow(t)      = wrap(t, Ansi::YELLOW)
  def cyan(t)        = wrap(t, Ansi::CYAN)
  def magenta(t)     = wrap(t, Ansi::MAGENTA)
  def bold_yellow(t) = wrap(t, Ansi::BOLD, Ansi::YELLOW)
  def bold_red(t)    = wrap(t, Ansi::BOLD, Ansi::RED)
end

RepoStatus = Struct.new(
  :path, :branch, :upstream, :ahead, :behind,
  :modified, :staged, :untracked, :deleted, :default_branch, :error,
  keyword_init: true
) do
  def dirty?    = modified.positive? || staged.positive? || untracked.positive? || deleted.positive?
  def unpushed? = ahead.positive?
  def off_main? = default_branch && branch && branch != default_branch && branch != "(detached)"
  def clean?    = error.nil? && !dirty? && ahead.zero? && behind.zero? && !off_main?
end

def query_repo(path)
  status = RepoStatus.new(
    path: path, branch: nil, upstream: nil, ahead: 0, behind: 0,
    modified: 0, staged: 0, untracked: 0, deleted: 0, default_branch: nil, error: nil
  )

  stdout, _stderr, ok = Open3.capture3("git", "-C", path.to_s, "status", "--porcelain=v2", "--branch")
  unless ok.success?
    status.error = "git status failed"
    return status
  end

  stdout.each_line do |line|
    line.chomp!
    case line
    when /\A# branch\.head (.+)\z/
      status.branch = $1
    when /\A# branch\.upstream (.+)\z/
      status.upstream = $1
    when /\A# branch\.ab \+(\d+) -(\d+)\z/
      status.ahead = $1.to_i
      status.behind = $2.to_i
    when /\A1 (\S\S) /
      xy = $1
      status.staged += 1 if xy[0] != "."
      status.modified += 1 if xy[1] == "M"
      status.deleted += 1 if xy[1] == "D"
    when /\A2 /
      status.modified += 1
    when /\Au /
      status.modified += 1
    when /\A\? /
      status.untracked += 1
    end
  end

  status.default_branch = detect_default_branch(path)
  status
end

def detect_default_branch(path)
  out, _err, ok = Open3.capture3("git", "-C", path.to_s, "symbolic-ref", "--short", "refs/remotes/origin/HEAD")
  return out.strip.split("/", 2).last if ok.success? && !out.strip.empty?

  %w[main master].each do |candidate|
    _, _, ok2 = Open3.capture3("git", "-C", path.to_s, "show-ref", "--verify", "--quiet", "refs/heads/#{candidate}")
    return candidate if ok2.success?
  end
  nil
end

def find_repos(root, ignore, max_depth)
  repos = []
  walk = lambda do |dir, depth|
    return if depth > max_depth
    return repos << dir if (dir + ".git").exist?

    begin
      dir.each_child do |entry|
        next if entry.symlink?
        next unless entry.directory?
        next if ignore.include?(entry.basename.to_s)
        walk.call(entry, depth + 1)
      end
    rescue Errno::EACCES, Errno::ENOENT
      # skip unreadable dirs
    end
  end
  walk.call(root, 0)
  repos.sort
end

def fetch_repo(path)
  Open3.capture3(
    "git",
    "-c", "http.lowSpeedLimit=1000",
    "-c", "http.lowSpeedTime=10",
    "-C", path.to_s,
    "fetch", "--quiet", "--no-tags", "--prune"
  )
  # Fetch failures (no remote, auth, offline) are non-fatal; status still works.
end

def collect_statuses(repos, fetch:, pool_size: 16)
  results = Array.new(repos.size)
  queue = (0...repos.size).to_a
  mutex = Mutex.new
  threads = pool_size.times.map do
    Thread.new do
      loop do
        idx = mutex.synchronize { queue.shift }
        break unless idx
        fetch_repo(repos[idx]) if fetch
        results[idx] = query_repo(repos[idx])
      end
    end
  end
  threads.each(&:join)
  results
end

def pad(coloured, plain, width)
  coloured + (" " * [width - plain.length, 0].max)
end

def render(scope, statuses, opts, c)
  total = statuses.size
  dirty = statuses.count(&:dirty?)
  unpushed = statuses.count(&:unpushed?)
  off_main = statuses.count(&:off_main?)
  scope_label = scope.to_s.sub(ENV["HOME"], "~")

  parts = [c.dim("#{total} #{total == 1 ? "repo" : "repos"}")]
  parts << c.yellow("#{dirty} dirty") if dirty.positive?
  parts << c.cyan("#{unpushed} unpushed") if unpushed.positive?
  parts << c.red("#{off_main} off-main") if off_main.positive?
  puts "#{c.bold(scope_label)} — #{parts.join(" · ")}"

  rows = statuses.reject { |s| !opts[:verbose] && s.clean? }
  return if rows.empty?

  puts

  rel = lambda do |s|
    r = s.path.relative_path_from(scope).to_s
    r == "." ? s.path.basename.to_s : r
  end

  path_w = rows.map { |s| rel.call(s).length }.max
  branch_w = rows.map { |s| (s.branch || "").length }.max
  flags_w = 14
  sync_w = 8

  rows.each do |s|
    path_str = rel.call(s).ljust(path_w)

    if s.error
      puts "#{path_str}  #{c.red("ERROR: #{s.error}")}"
      next
    end

    branch_plain = (s.branch || "").ljust(branch_w)
    branch_str = if s.off_main?
                   c.bold_yellow(branch_plain)
                 elsif s.clean?
                   c.dim(branch_plain)
                 else
                   c.dim(branch_plain)
                 end

    flag_tokens = []
    flag_plain = []
    if s.staged.positive?
      flag_tokens << c.green("S:#{s.staged}")
      flag_plain << "S:#{s.staged}"
    end
    if s.modified.positive?
      flag_tokens << c.yellow("M:#{s.modified}")
      flag_plain << "M:#{s.modified}"
    end
    if s.deleted.positive?
      flag_tokens << c.red("D:#{s.deleted}")
      flag_plain << "D:#{s.deleted}"
    end
    if s.untracked.positive?
      flag_tokens << c.dim("?:#{s.untracked}")
      flag_plain << "?:#{s.untracked}"
    end
    flags_str = pad(flag_tokens.join(" "), flag_plain.join(" "), flags_w)

    sync_tokens = []
    sync_plain = []
    if s.ahead.positive?
      sync_tokens << c.cyan("↑#{s.ahead}")
      sync_plain << "↑#{s.ahead}"
    end
    if s.behind.positive?
      sync_tokens << c.magenta("↓#{s.behind}")
      sync_plain << "↓#{s.behind}"
    end
    sync_str = pad(sync_tokens.join(" "), sync_plain.join(" "), sync_w)

    marker = s.off_main? ? c.bold_red("[off-main]") : ""

    puts "#{path_str}  #{branch_str}  #{flags_str}  #{sync_str}  #{marker}".rstrip
  end
end

def load_config
  return DEFAULT_CONFIG unless CONFIG_PATH.exist?
  loaded = YAML.load_file(CONFIG_PATH) || {}
  DEFAULT_CONFIG.merge(loaded)
end

def resolve_scope(arg, config, opts)
  base = Pathname.new(config["base"]).expand_path
  return base if opts[:all]
  return Pathname.new(config["default_scope"]).expand_path if arg.nil?
  return Pathname.new(arg).expand_path if arg.start_with?("/", "~", ".")
  base.join(arg)
end

def parse_opts(argv, config)
  opts = {
    verbose: false,
    all: false,
    fetch: config["fetch"] != false,
    colour: $stdout.tty? && !ENV.key?("NO_COLOR")
  }
  parser = OptionParser.new do |o|
    o.banner = "Usage: gits [options] [scope]\n\n" \
               "  scope: subdir under base (`gits goodbase`), explicit path (`gits ~/elsewhere`),\n" \
               "         or omitted to use default_scope.\n\nOptions:"
    o.on("-v", "--verbose", "Include clean repos") { opts[:verbose] = true }
    o.on("-a", "--all", "Scan the base directory regardless of default_scope") { opts[:all] = true }
    o.on("--[no-]fetch", "Fetch remotes before reporting status (default: on)") { |v| opts[:fetch] = v }
    o.on("--no-color", "Disable ANSI colour output") { opts[:colour] = false }
    o.on("-h", "--help", "Show this help") do
      puts o
      exit 0
    end
  end
  parser.parse!(argv)
  opts[:scope_arg] = argv.first
  opts
end

config = load_config
opts = parse_opts(ARGV, config)
scope = resolve_scope(opts[:scope_arg], config, opts)

unless scope.directory?
  warn "gits: #{scope} is not a directory"
  exit 1
end

painter = Painter.new(opts[:colour])
repos = find_repos(scope, Array(config["ignore"]), config["max_depth"] || 4)

if repos.empty?
  scope_label = scope.to_s.sub(ENV["HOME"], "~")
  puts "#{painter.bold(scope_label)} — #{painter.dim("0 repos")}"
  exit 0
end

statuses = collect_statuses(repos, fetch: opts[:fetch])
render(scope, statuses, opts, painter)
exit(statuses.any?(&:error) ? 1 : 0)
